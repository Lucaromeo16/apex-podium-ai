                  <td>{index + 1}</td>
                  <td>{driver.name}</td>
                  <td>{driver.team}</td>
                  <td>{driver.probability.toFixed(1)}%</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section className="card">
        <h2>Why Top Drivers Are Favored</h2>
        <p>{raceReasoning[selectedRace]}</p>
      </section>
    </div>
  );
}
export default App;